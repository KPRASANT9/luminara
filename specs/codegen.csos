// ═══ CSOS Codegen - Compiles .csos spec to LLVM IR ═══n// Target: src/native/compute/codegen.cppn// Purpose: Parse .csos spec → Generate LLVM IR → JIT compile → Executenn#include <llvm/IR/LLVMContext.h>n#include <llvm/IR/IRBuilder.h>n#include <llvm/IR/Module.h>n#include <llvm/IR/Verifier.h>n#include <llvm/ExecutionEngine/Orc/LLJIT.h>n#include <llvm/Support/TargetSelect.h>n#include <llvm/Support/raw_ostream.h>n#include <fstream>n#include <sstream>n#include <regex>n#include <map>nnnamespace csos {nn// ═══ Spec AST ═══nstruct Atom {n    std::string name;n    std::string formula;n    std::string source;n    std::map<std::string, double> params;n    std::string role;n};nnstruct Ring {n    std::string name;n    std::vector<std::string> atoms;n    std::string purpose;n};nnstruct Agent {n    std::string name;n    std::string mode;n    std::vector<std::string> loop_body;n};nnstruct Law {n    std::string name;n    std::string enforcement;n    std::vector<std::string> enforced_by;n};nn// ═══ CSOS Spec Parser ═══nclass SpecParser {npublic:n    std::vector<Atom> atoms;n    std::vector<Ring> rings;n    std::vector<Agent> agents;n    std::vector<Law> laws;nn    bool parse(const std::string& path) {n        std::ifstream file(path);n        if (!file.is_open()) return false;nn        std::string line;n        std::string current_section;n        Atom* current_atom = nullptr;n        Ring* current_ring = nullptr;n        Agent* current_agent = nullptr;n        Law* current_law = nullptr;nn        while (std::getline(file, line)) {n            trim(line);n            if (line.empty() || line.starts_with("//")) continue;nn            // Section detectionn            if (line.starts_with("atom ")) {n                current_atom = new Atom();n                current_atom->name = extract_name(line, "atom ");n                atoms.push_back(*current_atom);n                current_atom = nullptr;n            }n            else if (line.starts_with("ring ")) {n                current_ring = new Ring();n                current_ring->name = extract_name(line, "ring ");n                rings.push_back(*current_ring);n                current_ring = nullptr;n            }n            else if (line.starts_with("agent ")) {n                current_agent = new Agent();n                current_agent->name = extract_name(line, "agent ");n                agents.push_back(*current_agent);n                current_agent = nullptr;n            }n            else if (line.starts_with("law ")) {n                current_law = new Law();n                current_law->name = extract_name(line, "law ");n                laws.push_back(*current_law);n                current_law = nullptr;n            }n            // Field parsing (simplified)n            else if (current_atom) {n                parse_field(line, *current_atom);n            }n        }n        return true;n    }nnprivate:n    std::string extract_name(const std::string& line, const std::string& prefix) {n        size_t start = line.find(prefix) + prefix.size();n        size_t end = line.find("{");n        return line.substr(start, end - start);n    }nn    void parse_field(const std::string& line, Atom& atom) {n        if (line.find("formula:") != std::string::npos) {n            atom.formula = extract_value(line, "formula:");n        }n        else if (line.find("source:") != std::string::npos) {n            atom.source = extract_value(line, "source:");n        }n        else if (line.find("role:") != std::string::npos) {n            atom.role = extract_value(line, "role:");n        }n    }nn    std::string extract_value(const std::string& line, const std::string& key) {n        size_t start = line.find(key) + key.size();n        std::string val = line.substr(start);n        trim(val);n        if (val.back() == ',') val.pop_back();n        return val;n    }nn    void trim(std::string& s) {n        s.erase(0, s.find_first_not_of(" \t"));n        s.erase(s.find_last_not_of(" \t") + 1);n    }n};nn// ═══ LLVM IR Generator ═══nclass Codegen {n    llvm::LLVMContext context;n    llvm::IRBuilder<> builder;n    std::unique_ptr<llvm::Module> module;n    std::map<std::string, llvm::Value*> named_values;nnpublic:n    Codegen() : builder(context) {n        module = std::make_unique<llvm::Module>("csos_llvm", context);n    }nn    // ═══ Generate 5 Equation Functions ═══n    n    // Gouterman: dE = h * c / lambdan    llvm::Function* create_gouterman() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(), n            {builder.getDoubleTy()}, // lambdan            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "gouterman_dE", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        builder.SetInsertPoint(entry);n        n        llvm::Argument* lambda = fn->getArg(0);n        llvm::Value* h = builder.getConstantFP(llvm::APFloat(6.626e-34));n        llvm::Value* c = builder.getConstantFP(llvm::APFloat(2.998e8));n        llvm::Value* result = builder.CreateFDiv(builder.CreateFMul(h, c), lambda, "dE");n        n        builder.CreateRet(result);n        return fn;n    }nn    // Forster: k_ET = (1/t) * (R0/r)^6n    llvm::Function* create_forster() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(),n            {builder.getDoubleTy(), builder.getDoubleTy()}, // t, rn            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "forster_kET", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        builder.SetInsertPoint(entry);n        n        llvm::Argument* t = fn->getArg(0);n        llvm::Argument* r = fn->getArg(1);n        llvm::Value* one_over_t = builder.CreateFDiv(builder.getConstantFP(llvm::APFloat(1.0)), t, "inv_t");n        llvm::Value* R0 = builder.getConstantFP(llvm::APFloat(1.0)); // defaultn        llvm::Value* ratio = builder.CreateFDiv(R0, r, "ratio");n        llvm::Value* ratio_pow6 = builder.CreateFMul(ratio, ratio, "r2");n        ratio_pow6 = builder.CreateFMul(ratio_pow6, ratio_pow6, "r4");n        ratio_pow6 = builder.CreateFMul(ratio_pow6, ratio_pow6, "r6");n        llvm::Value* result = builder.CreateFMul(one_over_t, ratio_pow6, "k_ET");n        n        builder.CreateRet(result);n        return fn;n    }nn    // Marcus: k = exp(-(dG + λ)^2 / (4 * λ * kT))n    llvm::Function* create_marcus() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(),n            {builder.getDoubleTy(), builder.getDoubleTy()}, // dG, lambdan            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "marcus_k", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        builder.SetInsertPoint(entry);n        n        llvm::Argument* dG = fn->getArg(0);n        llvm::Argument* lambda = fn->getArg(1);n        llvm::Value* kT = builder.getConstantFP(llvm::APFloat(4.142e-21)); // 1.38e-23 * 300Kn        llvm::Value* num = builder.CreateFMul(builder.CreateFAdd(dG, lambda), builder.CreateFAdd(dG, lambda), "num");n        llvm::Value* denom = builder.CreateFMul(builder.getConstantFP(llvm::APFloat(4.0)), lambda, "den1");n        denom = builder.CreateFMul(denom, kT, "denom");n        llvm::Value* exponent = builder.CreateFNeg(builder.CreateFDiv(num, denom), "exponent");n        n        // exp() via LLVM intrinsicn        llvm::Function* exp_fn = llvm::Intrinsic::getDeclaration(module.get(), llvm::Intrinsic::exp, {builder.getDoubleTy()});n        llvm::Value* result = builder.CreateCall(exp_fn, {exponent}, "k");n        n        builder.CreateRet(result);n        return fn;n    }nn    // Mitchell: dG = -n * F * dy + 2.3 * R * T * dpHn    llvm::Function* create_mitchell() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(),n            {builder.getDoubleTy(), builder.getDoubleTy(), builder.getDoubleTy()}, // n, dy, dpHn            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "mitchell_dG", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        builder.SetInsertPoint(entry);n        n        llvm::Argument* n = fn->getArg(0);n        llvm::Argument* dy = fn->getArg(1);n        llvm::Argument* dpH = fn->getArg(2);n        llvm::Value* F = builder.getConstantFP(llvm::APFloat(96485.0)); // Faradayn        llvm::Value* term1 = builder.CreateFNeg(builder.CreateFMul(builder.CreateFMul(n, F), dy), "term1");n        llvm::Value* R = builder.getConstantFP(llvm::APFloat(8.314));n        llvm::Value* T = builder.getConstantFP(llvm::APFloat(300.0));n        llvm::Value* term2 = builder.CreateFMul(builder.getConstantFP(llvm::APFloat(2.3)), R, "t2a");n        term2 = builder.CreateFMul(term2, T, "t2b");n        term2 = builder.CreateFMul(term2, dpH, "term2");n        llvm::Value* result = builder.CreateFAdd(term1, term2, "dG");n        n        builder.CreateRet(result);n        return fn;n    }nn    // Boyer: ATP = flux * n / 3n    llvm::Function* create_boyer() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(),n            {builder.getDoubleTy(), builder.getDoubleTy()}, // flux, nn            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "boyer_ATP", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        builder.SetInsertPoint(entry);n        n        llvm::Argument* flux = fn->getArg(0);n        llvm::Argument* n = fn->getArg(1);n        llvm::Value* result = builder.CreateFDiv(builder.CreateFMul(flux, n), builder.getConstantFP(llvm::APFloat(3.0)), "ATP");n        n        builder.CreateRet(result);n        return fn;n    }nn    // ═══ Membrane Absorb Function (Main Loop) ═══n    llvm::Function* create_membrane_absorb() {n        llvm::FunctionType* ty = llvm::FunctionType::get(n            builder.getDoubleTy(), // returns decision (0=explore, 1=execute)n            {builder.getDoubleTy(), builder.getDoubleTy()}, // signal_in, rwn            falsen        );n        llvm::Function* fn = llvm::Function::Create(ty, llvm::Function::ExternalLinkage, "membrane_absorb", module.get());n        n        llvm::BasicBlock* entry = llvm::BasicBlock::Create(context, "entry", fn);n        llvm::BasicBlock* compute = llvm::BasicBlock::Create(context, "compute", fn);n        llvm::BasicBlock* decide = llvm::BasicBlock::Create(context, "decide", fn);n        n        builder.SetInsertPoint(entry);n        llvm::Argument* signal = fn->getArg(0);n        llvm::Argument* rw = fn->getArg(1);n        builder.CreateBr(compute);n        n        builder.SetInsertPoint(compute);n        // Call all 5 equation functionsn        llvm::Value* dE = builder.CreateCall(create_gouterman(), {signal}, "dE");n        llvm::Value* k_ET = builder.CreateCall(create_forster(), {builder.getConstantFP(llvm::APFloat(1.0)), signal}, "k_ET");n        llvm::Value* marcus_k = builder.CreateCall(create_marcus(), {dE, signal}, "marcus_k");n        llvm::Value* mitchell_dG = builder.CreateCall(create_mitchell(), {builder.getConstantFP(llvm::APFloat(1.0)), dE, signal}, "mitchell_dG");n        llvm::Value* boyer_ATP = builder.CreateCall(create_boyer(), {dE, marcus_k}, "boyer_ATP");n        builder.CreateBr(decide);n        n        builder.SetInsertPoint(decide);n        // Boyer decision: speed > rw ? EXECUTE : EXPLOREn        llvm::Value* speed = builder.CreateFAdd(builder.CreateFMul(boyer_ATP, mitchell_dG), k_ET, "speed");n        llvm::Value* cmp = builder.CreateFCmpOGE(speed, rw, "cmp");n        llvm::Value* decision = builder.CreateSelect(cmp, builder.getConstantFP(llvm::APFloat(1.0)), builder.getConstantFP(llvm::APFloat(0.0)), "decision");n        n        builder.CreateRet(decision);n        return fn;n    }nn    // ═══ JIT Compile and Execute ═══n    void finalize() {n        llvm::verifyModule(*module);n    }nn    std::string printIR() {n        std::string str;n        llvm::raw_string_ostream os(str);n        module->print(os, nullptr);n        return str;n    }n};nn// ═══ Main Entry Point ═══nint main(int argc, char** argv) {n    if (argc < 2) {n        llvm::errs() << "Usage: csos_codegen <spec.csos> [output.ll]\n";n        return 1;n    }nn    std::string spec_path = argv[1];n    std::string output_path = argc > 2 ? argv[2] : "csos.ll";nn    // Parse specn    SpecParser parser;n    if (!parser.parse(spec_path)) {n        llvm::errs() << "Failed to parse spec: " << spec_path << "\n";n        return 1;n    }n    llvm::errs() << "Parsed " << parser.atoms.size() << " atoms, "n                 << parser.rings.size() << " rings\n";nn    // Generate LLVM IRn    Codegen codegen;n    codegen.create_membrane_absorb();n    codegen.finalize();nn    // Output IRn    std::string ir = codegen.printIR();n    std::ofstream out(output_path);n    out << ir;n    out.close();nn    llvm::errs() << "Generated: " << output_path << "\n";n    return 0;n}nn} // namespace csosn