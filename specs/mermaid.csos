// ═══ CSOS Mermaid Renderer ═══n// Purpose: Visualize .csos spec as living diagram with state bindingnn#include <fstream>n#include <sstream>n#include <regex>n#include <map>n#include <vector>n#include <ctime>nnnamespace csos {nn// ═══ Mermaid Diagram Types ═══nenum DiagramType {n    FLOWCHART,    // Agent workflown    CLASS,        // Atom/Ring structure  n    STATE,        // State machinen    SEQUENCE      // Signal flown};nn// ═══ Diagram Node ═══nstruct DiagramNode {n    std::string id;n    std::string label;n    std::string shape;      // stadium, rhombus, circle, etc.n    std::string style;     // fill colorn    std::map<std::string, std::string> metadata;n};nnstruct DiagramEdge {n    std::string from;n    std::string to;n    std::string label;n    std::string style;n};nn// ═══ Mermaid Generator ═══nclass MermaidRenderer {n    std::vector<DiagramNode> nodes;n    std::vector<DiagramEdge> edges;n    DiagramType type;nnpublic:n    MermaidRenderer(DiagramType t = FLOWCHART) : type(t) {}nn    // ═══ Render from .csos spec ═══n    void render_from_spec(const std::string& spec_path, const std::string& state_path = "") {n        parse_spec_to_diagram(spec_path);n        if (!state_path.empty()) {n            bind_state(state_path);n        }n    }nn    std::string generate() {n        std::ostringstream out;n        n        switch (type) {n            case FLOWCHART: out << "flowchart TD\n"; break;n            case CLASS:     out << "classDiagram\n"; break;n            case STATE:     out << "stateDiagram-v2\n"; break;n            case SEQUENCE:  out << "sequenceDiagram\n"; break;n        }nn        // Generate nodesn        for (const auto& node : nodes) {n            out << "    " << node.id;n            if (!node.label.empty()) {n                out << "[" << node.label << "]";n                if (node.shape == "stadium") out << ":::atom";n                else if (node.shape == "rhombus") out << ":::decision";n            }n            out << "\n";n        }nn        // Generate edgesn        for (const auto& edge : edges) {n            out << "    " << edge.from << " -->|" << edge.label << "| " << edge.to << "\n";n        }nn        // Generate stylesn        out << "\n    style atom fill:#1a1a2e,stroke:#4a4e69,color:#fff\n";n        out << "    style decision fill:#16213e,stroke:#e94560,color:#fff\n";n        out << "    style ring fill:#0f3460,stroke:#533483,color:#fff\n";nn        return out.str();n    }nnprivate:n    void parse_spec_to_diagram(const std::string& spec_path) {n        std::ifstream file(spec_path);n        if (!file.is_open()) return;nn        std::string line;n        std::string current_section;n        int node_counter = 0;nn        while (std::getline(file, line)) {n            trim(line);n            if (line.empty() || line.starts_with("//")) continue;nn            // Section detectionn            if (line.starts_with("atom ")) {n                std::string name = extract_name(line, "atom ");n                DiagramNode node;n                node.id = "atom_" + std::to_string(node_counter++);n                node.label = name + "\n(dE = h·c/λ)";n                node.shape = "stadium";n                node.style = "atom";n                nodes.push_back(node);n            }n            else if (line.starts_with("ring ")) {n                std::string name = extract_name(line, "ring ");n                DiagramNode node;n                node.id = "ring_" + std::to_string(node_counter++);n                node.label = name + "\n[ECO]";n                node.shape = "cylinder";n                node.style = "ring";n                nodes.push_back(node);n            }n            else if (line.starts_with("agent ")) {n                std::string name = extract_name(line, "agent ");n                DiagramNode node;n                node.id = "agent_" + std::to_string(node_counter++);n                node.label = name + "\n(mode)";n                node.shape = "stadium";n                node.style = "agent";n                nodes.push_back(node);n            }n            else if (line.starts_with("law ")) {n                DiagramNode node;n                node.id = "law_" + std::to_string(node_counter++);n                node.label = extract_name(line, "law ");n                node.shape = "rhombus";n                node.style = "decision";n                nodes.push_back(node);n            }nn            // Connect atoms to ringsn            if (line == "}" && (current_section == "atom" || current_section == "ring")) {n                // Add edge between last atom and ringn                if (nodes.size() >= 2) {n                    DiagramEdge edge;n                    edge.from = nodes[nodes.size() - 2].id;n                    edge.to = nodes[nodes.size() - 1].id;n                    edge.label = "belongs_to";n                    edges.push_back(edge);n                }n            }n        }n    }nn    void bind_state(const std::string& state_path) {n        // Read .mem.json and bind real-time values to nodesn        std::ifstream state_file(state_path);n        if (!state_file.is_open()) return;nn        std::string state_json((std::istreambuf_iterator<char>(state_file)),n                                std::istreambuf_iterator<char>());nn        // Parse simple key:value pairs (delta, speed, rw, etc.)n        std::regex delta_rx("\"delta\"\\s*:\\s*([0-9.]+)");n        std::regex speed_rx("\"speed\"\\s*:\\s*([0-9.]+)");n        std::regex decision_rx("\"decision\"\\s*:\\s*\"([^\"]+)\"");nn        std::smatch match;n        if (std::regex_search(state_json, match, delta_rx)) {n            // Update Boyer node with delta valuen            for (auto& node : nodes) {n                if (node.id.find("boyer") != std::string::npos) {n                    node.label += "\nδ=" + match[1].str();n                }n            }n        }nn        if (std::regex_search(state_json, match, decision_rx)) {n            // Color decision node based on staten            for (auto& node : nodes) {n                if (node.id.find("law") != std::string::npos) {n                    node.style = (match[1].str() == "EXECUTE") ? "execute" : "explore";n                }n            }n        }n    }nn    std::string extract_name(const std::string& line, const std::string& prefix) {n        size_t start = line.find(prefix) + prefix.size();n        size_t end = line.find("{");n        return line.substr(start, end - start);n    }nn    void trim(std::string& s) {n        s.erase(0, s.find_first_not_of(" \t"));n        s.erase(s.find_last_not_of(" \t") + 1);n    }n};nn// ═══ Live Diagram Watcher ═══nclass LiveDiagram {n    std::string spec_path;n    std::string state_path;n    std::time_t last_spec_mtime;n    std::time_t last_state_mtime;nnpublic:n    LiveDiagram(const std::string& spec, const std::string& state)n        : spec_path(spec), state_path(state) {n        last_spec_mtime = get_mtime(spec_path);n        last_state_mtime = get_mtime(state_path);n    }nn    bool has_changes() {n        time_t spec_mtime = get_mtime(spec_path);n        time_t state_mtime = get_mtime(state_path);n        bool changed = (spec_mtime != last_spec_mtime) || (state_mtime != last_state_mtime);n        if (changed) {n            last_spec_mtime = spec_mtime;n            last_state_mtime = state_mtime;n        }n        return changed;n    }nn    std::string render() {n        MermaidRenderer renderer(FLOWCHART);n        renderer.render_from_spec(spec_path, state_path);n        return renderer.generate();n    }nnprivate:n    time_t get_mtime(const std::string& path) {n        struct stat st;n        if (stat(path.c_str(), &st) == 0) {n            return st.st_mtime;n        }n        return 0;n    }n};nn// ═══ Main ═══nint main(int argc, char** argv) {n    if (argc < 2) {n        printf("Usage: csos_mermaid <spec.csos> [state.json] [output.md]\n");n        return 1;n    }nn    std::string spec_path = argv[1];n    std::string state_path = argc > 2 ? argv[2] : ".csos/membrane/mem.json";n    std::string output_path = argc > 3 ? argv[3] : "diagram.md";nn    // Render oncen    MermaidRenderer renderer(FLOWCHART);n    renderer.render_from_spec(spec_path, state_path);n    std::string mermaid = renderer.generate();nn    // Outputn    std::ofstream out(output_path);n    out << "# Living Diagram (Auto-generated)\n\n";n    out << "```mermaid\n";n    out << mermaid;n    out << "```\n";n    out.close();nn    printf("Generated: %s\n", output_path.c_str());nn    // Optional: Watch moden    if (argc > 4 && std::string(argv[4]) == "--watch") {n        printf("Watching for changes...\n");n        LiveDiagram live(spec_path, state_path);n        while (true) {n            if (live.has_changes()) {n                std::string updated = live.render();n                std::ofstream out_watch(output_path);n                out_watch << "# Living Diagram (Live)\n\n```mermaid\n" << updated << "```\n";n                out_watch.close();n                printf("Diagram updated at %s\n", __TIME__);n            }n            std::this_thread::sleep_for(std::chrono::seconds(2));n        }n    }nn    return 0;n}nn} // namespace csosn