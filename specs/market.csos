causal_seed { cause: "sp500",     effect: "nifty50",   direction: "discover" }
causal_seed { cause: "dax",       effect: "ftse",      direction: "discover" }
causal_seed { cause: "nifty50",   effect: "hangseng",  direction: "discover" }

// ═══ LIMITS ═══

limit heisenberg    { value: "1bp"; source: "observation noise floor"; }
limit kolmogorov    { value: "32 atoms"; source: "model capacity per ring"; }
limit goedel        { value: "unavoidable"; source: "self-reference"; }
limit landauer      { value: "1e-15 J/absorb"; source: "computation cost"; }
limit photosynthesis { value: "95%"; source: "efficiency ceiling"; }
