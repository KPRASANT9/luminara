# CSOS V15 — MCP Server API Keys
# Copy to .env and fill in your keys. .env is gitignored.

# Alpaca — execution (the only egress MCP)
# https://alpaca.markets → Dashboard → API Keys
# PAPER=true uses simulated $100K. Set PAPER=false for live trading.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Alpha Vantage — technicals + macro
# https://www.alphavantage.co/support/#api-key
# Free: 25 req/day. Premium: 75 req/min.
ALPHA_VANTAGE_API_KEY=

# EODHD — tick data + Indian markets
# https://eodhd.com/register
EODHD_API_KEY=

# Financial Datasets — fundamentals + filings
# https://financialdatasets.ai → dashboard
FINANCIAL_DATASETS_API_KEY=
